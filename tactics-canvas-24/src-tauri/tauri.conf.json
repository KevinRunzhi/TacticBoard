{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "TacticBoard战术板",
  "version": "0.1.0",
  "identifier": "com.kevinrunzhi.tacticboard",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:8080",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "TacticBoard战术板",
        "width": 1440,
        "height": 900,
        "minWidth": 1280,
        "minHeight": 760,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self' customprotocol: asset:",
        "script-src": "'self'",
        "style-src": "'self' 'unsafe-inline'",
        "img-src": "'self' asset: data: blob:",
        "connect-src": "'self' ipc: http://ipc.localhost https://ipc.localhost",
        "font-src": "'self' asset: data:",
        "frame-ancestors": "'none'",
        "base-uri": "'self'",
        "form-action": "'self'"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
